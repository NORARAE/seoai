<?php

namespace App\Filament\Widgets;

use App\Models\PerformanceMetric;
use App\Models\Site;
use Filament\Widgets\ChartWidget;
use Illuminate\Support\Facades\DB;

class PerformanceTrendChart extends BaseWidget
{
    protected static ?string $heading = 'Performance Trend (Last 30 Days)';
    protected static ?int $sort = 3;
    protected int | string | array $columnSpan = 'full';

    protected function getData(): array
    {
        $clientId = auth()->user()?->client_id;

        // Get daily aggregated performance for last 30 days
        $data = PerformanceMetric::query()
            ->when($clientId, function($q) use ($clientId) {
                $q->whereIn('site_id', Site::where('client_id', $clientId)->pluck('id'));
            })
            ->where('date', '>=', now()->subDays(30))
            ->select([
                DB::raw('DATE(date) as day'),
                DB::raw('SUM(clicks) as total_clicks'),
                DB::raw('SUM(impressions) as total_impressions'),
                DB::raw('AVG(position) as avg_position'),
            ])
            ->groupBy('day')
            ->orderBy('day')
            ->get();

        $labels = $data->pluck('day')->map(fn($date) => 
            \Carbon\Carbon::parse($date)->format('M j')
        )->toArray();

        return [
            'datasets' => [
                [
                    'label' => 'Clicks',
                    'data' => $data->pluck('total_clicks')->toArray(),
                    'borderColor' => 'rgb(59, 130, 246)',
                    'backgroundColor' => 'rgba(59, 130, 246, 0.1)',
                ],
                [
                    'label' => 'Impressions',
                    'data' => $data->pluck('total_impressions')->toArray(),
                    'borderColor' => 'rgb(16, 185, 129)',
                    'backgroundColor' => 'rgba(16, 185, 129, 0.1)',
                ],
            ],
            'labels' => $labels,
        ];
    }

    protected function getType(): string
    {
        return 'line';
    }

    protected function getOptions(): array
    {
        return [
            'scales' => [
                'y' => [
                    'beginAtZero' => true,
                ],
            ],
            'plugins' => [
                'legend' => [
                    'display' => true,
                ],
            ],
        ];
    }
}
